# 환경변수 샘플 — 이 파일을 복사해서 .env.local 로 만들고 값을 채우세요.
# ⚠️ .env.local 은 깃(GitHub)에 올리지 않습니다. (비밀 키 노출 금지)

# Supabase — 프로젝트 설정 > API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://여기에-프로젝트-주소.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=여기에-anon-public-키

# 밥대생 Open API (bablabs) — https://bablabs.com/openapi/
# 없으면 대진대 샘플 식단 데이터로 동작합니다.
BABLABS_API_KEY=

# 식품의약품안전처 식품영양성분DB (I2790)
# https://www.foodsafetykorea.go.kr/api/openApiInfo.do?svc_no=I2790
FOOD_SAFETY_API_KEY=

# OpenAI (선택) — AI 조언 자연어 보강
OPENAI_API_KEY=

# ⚠️ service_role 키는 절대 여기 넣지 마세요. (브라우저에 노출되면 위험)
