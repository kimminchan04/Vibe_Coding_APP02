# 환경변수 샘플 파일입니다. 이 파일을 복사해서 .env.local로 만들고 값을 채우세요.
# .env.local은 GitHub에 올리지 마세요.

# Supabase 프로젝트 설정 > API에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Supabase 프로젝트 설정 > API > service_role (서버 전용, Git/브라우저에 노출 금지)
# 회원가입 시 이메일 확인 없이 계정을 바로 활성화하는 데 사용합니다.
SUPABASE_SERVICE_ROLE_KEY=

# 대진대학교 학식 크롤링 대상 URL
# 비워두면 앱에 포함된 기본 후보 URL을 먼저 시도하고, 실패 시 샘플 식단을 사용합니다.
DAEJIN_CAFETERIA_URL=

# OpenAI (선택) - AI 자연어 조언에 사용
OPENAI_API_KEY=

# service_role 키는 절대 여기에 넣지 마세요. 브라우저에 노출되면 위험합니다.
